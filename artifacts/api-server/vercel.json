{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "dist/**,node_modules/connect-pg-simple/**,node_modules/.pnpm/connect-pg-simple@*/node_modules/connect-pg-simple/**"
    },
    "api/[...path].js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "dist/**,node_modules/connect-pg-simple/**,node_modules/.pnpm/connect-pg-simple@*/node_modules/connect-pg-simple/**"
    }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/api/robots.txt" },
    { "source": "/feed.xml", "destination": "/api/feed.xml" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm -w run build:vercel",
  "outputDirectory": "artifacts/blog/dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "api/**,api-lib/**,artifacts/api-server/dist/**,node_modules/pg/**"
    },
    "api/[...path].js": {
      "maxDuration": 30,
      "includeFiles": "api/**,api-lib/**,artifacts/api-server/dist/**,node_modules/pg/**"
    }
  },
  "redirects": [],
  "headers": [
    {
      "source": "/api/auth/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:jpg|jpeg|png|gif|webp|svg|ico|woff2?))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/>; rel=\"canonical\"" }]
    },
    {
      "source": "/about",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/about>; rel=\"canonical\"" }]
    },
    {
      "source": "/about/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/about>; rel=\"canonical\"" }]
    },
    {
      "source": "/ai",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/ai>; rel=\"canonical\"" }]
    },
    {
      "source": "/ai/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/ai>; rel=\"canonical\"" }]
    },
    {
      "source": "/api-sources",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/api-sources>; rel=\"canonical\"" }]
    },
    {
      "source": "/api-sources/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/api-sources>; rel=\"canonical\"" }]
    },
    {
      "source": "/challenges",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/challenges>; rel=\"canonical\"" }]
    },
    {
      "source": "/challenges/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/challenges>; rel=\"canonical\"" }]
    },
    {
      "source": "/community",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/community>; rel=\"canonical\"" }]
    },
    {
      "source": "/community/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/community>; rel=\"canonical\"" }]
    },
    {
      "source": "/contact",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/contact>; rel=\"canonical\"" }]
    },
    {
      "source": "/contact/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/contact>; rel=\"canonical\"" }]
    },
    {
      "source": "/interview",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/interview>; rel=\"canonical\"" }]
    },
    {
      "source": "/interview/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/interview>; rel=\"canonical\"" }]
    },
    {
      "source": "/jobs",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/jobs>; rel=\"canonical\"" }]
    },
    {
      "source": "/jobs/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/jobs>; rel=\"canonical\"" }]
    },
    {
      "source": "/learn",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/learn>; rel=\"canonical\"" }]
    },
    {
      "source": "/learn/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/learn>; rel=\"canonical\"" }]
    },
    {
      "source": "/playground",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/playground>; rel=\"canonical\"" }]
    },
    {
      "source": "/playground/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/playground>; rel=\"canonical\"" }]
    },
    {
      "source": "/refs",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/refs>; rel=\"canonical\"" }]
    },
    {
      "source": "/refs/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/refs>; rel=\"canonical\"" }]
    },
    {
      "source": "/resources",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/resources>; rel=\"canonical\"" }]
    },
    {
      "source": "/resources/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/resources>; rel=\"canonical\"" }]
    },
    {
      "source": "/roadmaps",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/roadmaps>; rel=\"canonical\"" }]
    },
    {
      "source": "/roadmaps/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/roadmaps>; rel=\"canonical\"" }]
    },
    {
      "source": "/search",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/search>; rel=\"canonical\"" }]
    },
    {
      "source": "/search/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/search>; rel=\"canonical\"" }]
    },
    {
      "source": "/snippets",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/snippets>; rel=\"canonical\"" }]
    },
    {
      "source": "/snippets/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/snippets>; rel=\"canonical\"" }]
    },
    {
      "source": "/templates",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/templates>; rel=\"canonical\"" }]
    },
    {
      "source": "/templates/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/templates>; rel=\"canonical\"" }]
    },
    {
      "source": "/tools",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/tools>; rel=\"canonical\"" }]
    },
    {
      "source": "/tools/",
      "headers": [{ "key": "Link", "value": "<https://www.techventry.com/tools>; rel=\"canonical\"" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://plausible.io https://pagead2.googlesyndication.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https: wss:; frame-src 'self' https://googleads.g.doubleclick.net https://tpc.googlesyndication.com"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/sync/cron",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/api/robots.txt" },
    { "source": "/feed.xml", "destination": "/api/feed.xml" },
    {
      "source": "/((?!api(?:/|$)|assets/|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "BASE_PATH": "/",
      "PORT": "3000",
      "NODE_ENV": "production"
    }
  }
}

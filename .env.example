# =============================================================================
# Local development — copy to .env
# =============================================================================

DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Supabase pooler (recommended for Vercel/serverless — port 6543, transaction mode):
# DATABASE_POOLER_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true
# DATABASE_POOL_MAX=2
# DATABASE_IDLE_TIMEOUT_MS=10000
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_RECOVERY_TOKEN=your-recovery-token
PORT=8080
BASE_PATH=/

# =============================================================================
# Vercel — add these in Project Settings → Environment Variables
# =============================================================================
#
# Required (Production + Preview + Development):
#
#   DATABASE_URL
#     Supabase Postgres connection string.
#     Password must be URL-encoded if it contains special characters (@ # $ etc).
#     Example: postgresql://postgres:ENCODED_PASS@db.xxx.supabase.co:5432/postgres
#
#   DATABASE_POOLER_URL (strongly recommended on Vercel)
#     Supabase connection pooler — use port 6543 with ?pgbouncer=true for serverless.
#     Keeps Postgres connection count low when many users hit the site at once.
#
#   CRON_SECRET
#     Random string for Vercel Cron auth (Bearer token on /api/jobs/sync/cron).
#     Generate: openssl rand -base64 32
#
#   API_RATE_LIMIT_PER_MIN=300   global API limit per IP (default 300)
#   AI_RATE_LIMIT_PER_MIN=20     AI chat messages per IP per minute (default 20)
#   MYMEMORY_EMAIL=you@email.com  Registered email for MyMemory — ~50k chars/day free (job translation)
#   CDN_CACHE_SECONDS=600        edge cache TTL override for public GET responses
#
#   SESSION_SECRET
#     Long random string for signing session cookies (admin + public site users).
#     Generate: openssl rand -base64 32
#
#   SITE_URL
#     Canonical production URL (e.g. https://techventry.com).
#     Used for GitHub OAuth callback and email links.
#
# Optional (seed first admin row only — login uses DB after that):
#
#   ADMIN_USERNAME          default: admin
#   ADMIN_PASSWORD          default: admin123
#   ADMIN_RECOVERY_TOKEN    legacy env-token reset at /api/auth/forgot-password/legacy
#
# Email (Resend — https://resend.com):
#
#   RESEND_API_KEY          your Resend API key
#   RESEND_FROM_EMAIL=TechVentry <info@techventry.com>
#   ADMIN_EMAIL=info@techventry.com
#
# Database migrations (run once per environment — local or against production DB):
#
#   pnpm --filter @workspace/db run migrate:all
#     — or individually:
#   pnpm --filter @workspace/db run migrate:platform
#   pnpm --filter @workspace/db run migrate:admin
#   pnpm --filter @workspace/db run migrate:jobs
#   pnpm --filter @workspace/db run migrate:site-users
#   pnpm --filter @workspace/db run migrate:storage
#   pnpm --filter @workspace/db run seed:platform
#
# Public user accounts (/signup, /login):
#   Uses site_users table + SESSION_SECRET (no extra env vars).
#   Rate-limited: 5 signups / 15 min per IP, 20 logins / 15 min per IP.
#
# Optional — Platform features (AI, playground, challenges, jobs, community):
#
#   (see migrate commands above)
#
# Optional — External job aggregation (RemoteOK, Remotive, Arbeitnow, The Muse, Jooble, Ever Jobs):
#
#   JOBS_SYNC_ENABLED=true              sync on startup + daily (local/long-running only)
#   JOBS_SYNC_INTERVAL_HOURS=24         how often to check APIs for new jobs
#   On Vercel, job sync runs via cron (/api/jobs/sync/cron) — not on every page view.
#   JOOBLE_API_KEY=...                  free at https://jooble.org/api/about
#   JOOBLE_SEARCH_KEYWORDS=software engineer Pakistan,developer Karachi Pakistan
#   JOBS_JOOBLE_MAX_PAGES=8             pages per keyword search
#   EVER_JOBS_BASE_URL=http://localhost:3001   self-hosted Ever Jobs API
#   EVER_JOBS_API_KEY=...               optional if Ever Jobs auth enabled
#   THE_MUSE_API_KEY=...                optional — public API works without key
#
# Optional — AI Developer Assistant (free providers only in chat fallback):
#
#   AI_PROVIDER=auto          auto | zai | groq | gemini | cerebras | nvidia | ...
#
# Optional — Z.ai free GLM Flash (https://z.ai/model-api, https://docs.z.ai/guides/overview/quick-start):
#
#   ZAI_GLM_47_FLASH_KEY=...       GLM-4.7-Flash (text)
#   ZAI_GLM_47_FLASH_MODEL=glm-4.7-flash
#   ZAI_GLM_45_FLASH_KEY=...       GLM-4.5-Flash (text)
#   ZAI_GLM_45_FLASH_MODEL=glm-4.5-flash
#   ZAI_GLM_46V_FLASH_KEY=...      GLM-4.6V-Flash (vision; works for text chat)
#   ZAI_GLM_46V_FLASH_MODEL=glm-4.6v-flash
#   ZAI_API_KEY=...                single-key shortcut (optional)
#   ZAI_MODEL=glm-4.7-flash
#   ZAI_BASE_URL=https://api.z.ai/api/paas/v4
#
#   GROQ_API_KEY=gsk_...           free at https://console.groq.com
#   GROQ_MODEL=llama-3.3-70b-versatile
#   GEMINI_API_KEY=...             https://aistudio.google.com/apikey
#   GEMINI_MODEL=gemini-2.0-flash
#   CEREBRAS_API_KEY=...           https://cloud.cerebras.ai/
#   CEREBRAS_MODEL=llama-3.3-70b
#   NVIDIA_MODEL_API_KEYS={"meta/llama-3.3-70b-instruct":"nvapi-...","qwen/qwen3-next-80b-a3b-instruct":"nvapi-...","deepseek-ai/deepseek-v4-flash":"nvapi-..."}
#   NVIDIA_API_KEY=nvapi-...       default / fallback key from build.nvidia.com
#   NVIDIA_CHAT_KEY=nvapi-...        chat modes (optional — falls back to NVIDIA_API_KEY)
#   NVIDIA_CODE_KEY=nvapi-...        generate/debug/sql/api modes
#   NVIDIA_REASONING_KEY=nvapi-...   explain/errors modes
#   NVIDIA_IMAGE_KEY=nvapi-...       qwen-image / FLUX / SD image generation
#   NVIDIA_CHAT_MODEL=qwen/qwen3-next-80b-a3b-instruct     model ID, not an API key
#   NVIDIA_CODE_MODEL=qwen/qwen3.5-122b-a10b
#   NVIDIA_REASONING_MODEL=deepseek-ai/deepseek-v4-pro
#   NVIDIA_IMAGE_MODEL=qwen/qwen-image                      POST /api/media/ai-image/generate
#   NVIDIA_MODEL=meta/llama-3.3-70b-instruct            single-model override for all modes
#   SAMBANOVA_API_KEY=...          https://cloud.sambanova.ai/
#   SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
#   HF_TOKEN=hf_...                https://huggingface.co/settings/tokens
#   HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
#   OPENROUTER_API_KEY=sk-or-...   https://openrouter.ai/ (use :free models)
#   OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   MODELSCOPE_API_KEY=...         https://www.modelscope.cn/my/myaccesstoken
#   MODELSCOPE_MODEL=Qwen/Qwen2.5-72B-Instruct
#   SILICONFLOW_API_KEY=...        https://cloud.siliconflow.cn/
#   SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
#   DEEPSEEK_API_KEY=sk-...        https://platform.deepseek.com/
#   DEEPSEEK_MODEL=deepseek-chat
#   OPENAI_API_KEY=sk-...          https://platform.openai.com/
#   OPENAI_MODEL=gpt-4o-mini
#   OLLAMA_API_KEY=...             create at https://ollama.com (Cloud API key)
#   OLLAMA_BASE_URL=https://ollama.com/v1
#   OLLAMA_MODEL=gemma3:4b         free cloud models: gemma3:4b, gpt-oss:120b
#                                  local: OLLAMA_BASE_URL=http://localhost:11434/v1
#
#   NVIDIA image models (qwen-image, FLUX, SD 3.5) appear in the chat model picker as
#   "NVIDIA Image · … (image)" — select one and describe what to generate.
#
# Other paid / reference-only providers (API Sources page):
#   TOGETHER_API_KEY, MISTRAL_API_KEY
#
# Optional — translation fallback (no key on public instance):
#
#   LIBRETRANSLATE_URL=https://libretranslate.com
#   LIBRETRANSLATE_API_KEY=...   optional for self-hosted instances
#
# Optional — distributed cache & rate limits (Upstash free tier):
#
#   UPSTASH_REDIS_REST_URL=...
#   UPSTASH_REDIS_REST_TOKEN=...
#
# Optional — email fallbacks (Resend is primary):
#
#   SENDGRID_API_KEY=...
#   SENDGRID_FROM_EMAIL=TechVentry <info@techventry.com>
#   BREVO_API_KEY=...
#   BREVO_FROM_EMAIL=TechVentry <info@techventry.com>
#
# Optional — GitHub OAuth (community sign-in):
#
#   GITHUB_CLIENT_ID=...
#   GITHUB_CLIENT_SECRET=...
#   Callback URL: {SITE_URL}/api/auth/github/callback
#
# Optional — dev feeds & content APIs:
#
#   DEVTO_API_KEY=...         optional; public Dev.to feed works without key
#   NEWS_API_KEY=...          https://newsapi.org/register
#   GNEWS_API_KEY=...         https://gnews.io/
#   UNSPLASH_ACCESS_KEY=...   https://unsplash.com/oauth/applications
#   PEXELS_API_KEY=...        https://www.pexels.com/api/
#   COINGECKO_API_KEY=...     optional; demo tier works without key
#
# Optional — Supabase Storage (admin image upload):
#
#   1. Run migration:  pnpm --filter @workspace/db run migrate:storage
#   2. Supabase Dashboard → Project Settings → API → service_role key
#
#   SUPABASE_URL              https://YOUR_PROJECT.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY   service_role secret (never expose in frontend)
#   SUPABASE_STORAGE_BUCKET   default: blog-images
#
# Optional — paid AI (API Sources reference only; not used in free chat fallback):
#
#   OPENAI_API_KEY, OPENAI_MODEL=gpt-4o-mini
#
# Prefer free providers: see AI Developer Assistant section above.
#
# Optional — frontend (Vite, prefix VITE_):
#
#   VITE_GA_ID                Google Analytics
#   VITE_PLAUSIBLE_DOMAIN     Plausible analytics domain
#   VITE_ADSENSE_CLIENT       Google AdSense client ID
#
# Set automatically by Vercel (do not add manually):
#
#   NODE_ENV=production
#   VERCEL=1
#   VERCEL_URL              e.g. your-app.vercel.app
#
# Set in vercel.json build env (already configured):
#
#   BASE_PATH=/
#   PORT=3000
#
# =============================================================================
